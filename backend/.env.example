# ============== Plantilla Full-Stack — Backend ==============

APP_NAME="MiApp"
MONGO_URL="mongodb://localhost:27017"
DB_NAME="miapp_db"
CORS_ORIGINS="http://localhost:3000"

COOKIE_SECURE=false
COOKIE_SAMESITE=lax

JWT_SECRET="cambiar-por-un-secreto-aleatorio-de-64-caracteres-hex"

ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="Admin123!"
USER_EMAIL="usuario@example.com"
USER_PASSWORD="Usuario123!"

# ============== Pagos (opcional) ==============
PAYMENTS_ENABLED=false
PAYMENT_PROVIDER=wompi
PAYMENTS_MIN_AMOUNT_CENTS=100000
PAYMENTS_MAX_AMOUNT_CENTS=500000000
PAYMENTS_SUPPORTED_CURRENCIES=COP
WOMPI_ENV=sandbox
WOMPI_PUBLIC_KEY=
WOMPI_PRIVATE_KEY=
WOMPI_EVENTS_SECRET=
WOMPI_INTEGRITY_SECRET=

# ============== Fabrica / builds ==============
# Con ANTHROPIC_API_KEY o key BYOK en la UI → Agent real
BUILDS_ENABLED=false
ANTHROPIC_API_KEY=

# Topes (USD). Defaults nuevos: 5 por build / 50 al día (antes 0.50 cortaba todo).
BUILDS_DAILY_BUDGET_USD=50
BUILDS_PER_BUILD_CAP_USD=5.00
# Tope específico modo guía (learn); no hace falta que sea tan alto como implement
BUILDS_LEARN_BUDGET_USD=2.00

BUILDS_MAX_QUEUE_DEPTH=10
BUILDS_MAX_TURNS=60
BUILDS_TIMEOUT_SECONDS=900
BUILDS_WORK_ROOT=/tmp/builds
# BUILDS_TEMPLATE_ROOT=

# Modelos Anthropic (alias UI → id real)
# BUILDS_MODEL_HAIKU=claude-haiku-4-5-20251001
# BUILDS_MODEL_SONNET=claude-sonnet-5
# BUILDS_MODEL_OPUS=claude-opus-4-8

# ============== Plantilla Full-Stack — Backend ==============

# Nombre visible de la app (titulo de la API, logs). Bautiza tu proyecto aqui.
APP_NAME="MiApp"

# Cadena de conexion a MongoDB (local o Atlas)
MONGO_URL="mongodb://localhost:27017"

# Nombre de la base de datos que usara la app
DB_NAME="miapp_db"

# Origenes permitidos para CORS, separados por coma (URL del frontend)
CORS_ORIGINS="http://localhost:3000"

# Opcional: patron regex de origenes permitidos (para previews con URL dinamica).
# IMPORTANTE: anclar al proyecto/team real, NUNCA "https://.*\.vercel\.app" a secas
# -- ese patron acepta el subdominio de CUALQUIER proyecto de Vercel de CUALQUIER
# persona, lo que con cookies cross-site (ver COOKIE_SAMESITE abajo) abre CSRF.
# Ejemplo anclado: "https://mi-app(-git-[a-z0-9-]+)?-mi-usuario\.vercel\.app"
# CORS_ORIGIN_REGEX=

# Flags de cookies de sesion. En local (mismo sitio, http) el default sirve tal
# cual. Si frontend y backend quedan en dominios DISTINTOS (ej. Vercel + Render),
# el navegador no envia cookies SameSite=Lax en llamadas cross-site: hay que
# poner COOKIE_SAMESITE=none, lo que a su vez exige COOKIE_SECURE=true (spec de
# navegadores). La app falla al arrancar si se pone "none" sin "true".
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# Secreto para firmar los JWT. Generar uno propio: openssl rand -hex 32
JWT_SECRET="cambiar-por-un-secreto-aleatorio-de-64-caracteres-hex"

# Credenciales del administrador semilla (se crea automaticamente al arrancar)
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="Admin123!"

# Credenciales del usuario final semilla (se crea automaticamente al arrancar)
USER_EMAIL="usuario@example.com"
USER_PASSWORD="Usuario123!"

# ============== Modulo de pagos (opcional) — ver docs/PAGOS.md ==============
# Apagado por defecto. Si esta en false/ausente, el resto de estas variables
# NO se validan y la app arranca exactamente igual que sin este modulo.
PAYMENTS_ENABLED=false

# Unico valor soportado en v1. Deja la puerta abierta a otros proveedores
# (habria que escribir un adaptador nuevo en backend/payments/providers/).
PAYMENT_PROVIDER=wompi

# Limites anti-abuso en centavos (COP no tiene sub-unidad real: los montos
# deben ser multiplos de 100). Ejemplo: $1.000 a $5.000.000 COP.
PAYMENTS_MIN_AMOUNT_CENTS=100000
PAYMENTS_MAX_AMOUNT_CENTS=500000000
PAYMENTS_SUPPORTED_CURRENCIES=COP

# Credenciales de Wompi (panel de comercio -> Desarrolladores). "sandbox" no
# requiere cuenta de comercio verificada, solo un correo. NUNCA valores reales
# en este archivo -- son solo el placeholder documentado.
WOMPI_ENV=sandbox
WOMPI_PUBLIC_KEY=
WOMPI_PRIVATE_KEY=
# Secreto de eventos/webhooks (distinto de las llaves de arriba) -- panel de
# Wompi -> Desarrolladores -> Eventos.
WOMPI_EVENTS_SECRET=
# Secreto de integridad -- panel de Wompi -> Desarrolladores -> Llaves.
WOMPI_INTEGRITY_SECRET=

# ============== Modulo de builds / Fabrica (opcional) ==============
BUILDS_ENABLED=false
ANTHROPIC_API_KEY=
BUILDS_DAILY_BUDGET_USD=20
BUILDS_PER_BUILD_CAP_USD=0.50
BUILDS_MAX_QUEUE_DEPTH=10
BUILDS_MAX_TURNS=40
BUILDS_TIMEOUT_SECONDS=600
BUILDS_WORK_ROOT=/tmp/builds

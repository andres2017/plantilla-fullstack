{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          { "type": "command", "command": "bash .claude/hooks/lint-python.sh", "timeout": 30 },
          { "type": "command", "command": "bash .claude/hooks/lint-frontend.sh", "timeout": 30 }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          { "type": "command", "command": "bash .claude/hooks/block-env-edit.sh", "timeout": 10 }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "bash .claude/hooks/check-secrets.sh", "if": "Bash(git commit*)", "timeout": 15 }
        ]
      }
    ]
  }
}

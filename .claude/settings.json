{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/block_env_edit.py",
            "timeout": 10,
            "statusMessage": "Verificando que no sea un .env protegido..."
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/check_secrets.py",
            "timeout": 20,
            "statusMessage": "Buscando secretos hardcodeados antes del commit..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/lint_python.py",
            "timeout": 25,
            "statusMessage": "Linteando .py con ruff..."
          }
        ]
      }
    ]
  }
}
